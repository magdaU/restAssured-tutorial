{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id":          { "type": "integer" },
    "name":        { "type": "string" },
    "releaseDate": { "type": "string" },
    "reviewScore": { "type": "integer" },
    "category":    { "type": "string" },
    "rating":      { "type": "string" }
  },
  "required": ["id", "name", "category", "rating", "releaseDate", "reviewScore"]
}